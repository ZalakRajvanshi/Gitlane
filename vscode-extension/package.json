{
  "name": "gitmind-vscode",
  "displayName": "GitMind — AI Commits & Secret Guard",
  "description": "AI commit messages (Conventional Commits) + automatic secret detection and auto-fix to .env. One-click commit, push, and GitHub repo creation. A free, local Copilot alternative for commit messages.",
  "version": "0.1.1",
  "publisher": "zalakrajvanshi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZalakRajvanshi/Git-mind.git"
  },
  "homepage": "https://github.com/ZalakRajvanshi/Git-mind#readme",
  "bugs": { "url": "https://github.com/ZalakRajvanshi/Git-mind/issues" },
  "engines": { "vscode": "^1.85.0" },
  "categories": ["SCM Providers", "AI", "Machine Learning"],
  "keywords": [
    "ai",
    "ai commit",
    "ai commit message",
    "commit message",
    "commit message generator",
    "conventional commits",
    "smart commit",
    "git ai",
    "git assistant",
    "secret scanner",
    "secret detection",
    "credential scanner",
    "gitleaks",
    "detect secrets",
    "leaked api key",
    "env",
    "dotenv",
    "one click commit",
    "copilot alternative",
    "groq",
    "llama",
    "github",
    "productivity",
    "streak"
  ],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "gitmind.commitNow",     "title": "GitMind: Commit Now (AI message + secret scan + push)" },
      { "command": "gitmind.ask",           "title": "GitMind: Ask a Question About My Work" },
      { "command": "gitmind.openDashboard", "title": "GitMind: Open Dashboard (Browser)" },
      { "command": "gitmind.showMenu",      "title": "GitMind: Show Menu" }
    ],
    "configuration": {
      "title": "GitMind",
      "properties": {
        "gitmind.projectRoot": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the GitMind project folder (the one containing data/gitmind.db and .env). Asked on first run."
        },
        "gitmind.dashboardUrl": {
          "type": "string",
          "default": "http://localhost:7123",
          "description": "Where the optional Python browser dashboard runs (only used by the 'Open Dashboard' command)."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch":   "tsc -p . -w"
  },
  "dependencies": {
    "sql.js": "^1.10.3"
  },
  "devDependencies": {
    "@types/node":   "^20.11.0",
    "@types/sql.js": "^1.4.9",
    "@types/vscode": "^1.85.0",
    "typescript":    "^5.4.0"
  }
}
